# ===========================================
# Did You Know Service - Environment Variables
# ===========================================

# Application
APP_NAME=Did You Know Service API
APP_VERSION=1.0.0
DEBUG=True

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# API Key
NEXT_API_ROUTE_KEY=your-api-key-here

# Ollama (로컬 LLM)
OLLAMA_URL=http://localhost:11434

# Swagger Docs
ENABLE_DOCS=True
DOCS_USERNAME=admin
DOCS_PASSWORD=changeme
