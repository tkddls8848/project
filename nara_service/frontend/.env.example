# ===========================================
# Frontend Environment Variables (템플릿)
# ===========================================
# 사용법:
# 1. 이 파일을 .env로 복사: cp .env.example .env
# 2. 아래 값들을 실제 값으로 변경
# ===========================================

# Backend API URL
# 로컬 개발: http://127.0.0.1:8000
# 프로덕션: https://your-backend.railway.app
BACKEND_API_URL=http://127.0.0.1:8000

# Backend API Key (백엔드와 동일한 값 사용)
# 생성: openssl rand -hex 32
NEXT_API_ROUTE_KEY=your-api-key-here

# NextAuth 설정
NEXTAUTH_URL=http://localhost:3000
# 생성: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# Google OAuth (선택사항)
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Admin Emails (쉼표로 구분)
# 이 이메일 주소로 로그인한 사용자는 admin role을 받습니다
ADMIN_EMAILS=tkddls8848@gmail.com
