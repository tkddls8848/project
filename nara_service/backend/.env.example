# ===========================================
# Backend Environment Variables (템플릿)
# ===========================================
# 사용법:
# 1. 이 파일을 .env로 복사: cp .env.example .env
# 2. 아래 값들을 실제 값으로 변경
# ===========================================

# Application
APP_NAME=NARA Service API
APP_VERSION=1.0.0
# 로컬: True, Railway(프로덕션): False
DEBUG=True

# CORS (허용할 프론트엔드 도메인)
# 로컬: http://localhost:5173,http://localhost:3000
# Railway: https://your-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# API Key (프론트엔드와 동일한 값 사용)
# 생성: openssl rand -hex 32
NEXT_API_ROUTE_KEY=your-api-key-here

# API Prefix
API_V1_PREFIX=/api/v1

# OpenAI API (RAG 기능용)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Ollama (로컬 LLM, 선택사항)
OLLAMA_URL=http://localhost:11434

# Swagger Docs
# 로컬: True, Railway(프로덕션): False 권장
ENABLE_DOCS=True
DOCS_USERNAME=admin
DOCS_PASSWORD=changeme

# Neo4j Database
# 로컬 환경 (백엔드 로컬 실행): bolt://localhost:17687
# 로컬 환경 (Docker Compose 내부): bolt://neo4j:7687
# Railway (Neo4j 서비스): bolt://neo4j.railway.internal:7687
# Railway (Neo4j Aura): neo4j+s://xxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:17687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
