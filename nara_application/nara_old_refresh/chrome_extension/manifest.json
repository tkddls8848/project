{
  "manifest_version": 3,
  "name": "공공데이터포털 자동 승인",
  "version": "1.0.0",
  "description": "공공데이터포털의 API 활용 신청을 자동으로 연장 승인하는 도구",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "https://www.data.go.kr/*",
    "https://auth.data.go.kr/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.data.go.kr/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
