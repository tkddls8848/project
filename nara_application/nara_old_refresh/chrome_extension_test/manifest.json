{
  "manifest_version": 3,
  "name": "공공데이터포털 자동 연장 (Nara Refresh - UI)",
  "version": "1.1",
  "description": "공공데이터포털 데이터 활용 신청 자동 연장 도구 (UI Automation)",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.data.go.kr/*",
    "https://auth.data.go.kr/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.data.go.kr/*", "https://auth.data.go.kr/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["https://*.data.go.kr/*", "https://auth.data.go.kr/*"]
    }
  ]
}