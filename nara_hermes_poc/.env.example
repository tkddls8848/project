NARA_SEARCH_URL=http://127.0.0.1:8000
NARA_COMBINER_URL=http://127.0.0.1:8003
NARA_REQUEST_TIMEOUT=30
NARA_COMPOSE_TIMEOUT=240

# OpenAI is used only by the Hermes judgement profile. Copy this file to .env
# and insert your key locally; .env is excluded from Git.
OPENAI_API_KEY=
NARA_HERMES_PROFILE=nara-openai
NARA_HERMES_MODEL=gpt-5.4-mini
NARA_HERMES_TIMEOUT=75
NARA_HERMES_PROBE=1
