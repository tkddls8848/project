{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gov24_link_candidate.schema.json",
  "title": "Gov24 Link Candidate",
  "type": "object",
  "required": ["candidate_id", "title", "url", "source", "review_status"],
  "additionalProperties": false,
  "properties": {
    "candidate_id": {
      "type": "string",
      "pattern": "^candidate:[a-z0-9_]+:[0-9]+$"
    },
    "title": { "type": "string", "minLength": 1 },
    "url": {
      "type": "string",
      "pattern": "^https?://.+"
    },
    "source": {
      "type": "string",
      "enum": ["manual", "search", "crawler", "api"]
    },
    "matched_query": { "type": "string" },
    "matched_service_name": { "type": "string" },
    "match_reason": { "type": "string" },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "review_status": {
      "type": "string",
      "enum": ["pending", "reviewed", "rejected"]
    },
    "notes": { "type": "string" }
  }
}
