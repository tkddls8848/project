# ─────────────────────────────────────────────
# 데이터 / 모델 / 인덱스 (전 프로젝트 일괄)
# ─────────────────────────────────────────────

# 원본 / 정제 / 출력
# ※ **/data/는 nara_dashboard/src/data 같은 React 소스 폴더까지 잡아서 사용 금지
#    → 크롤러 산출 폴더만 프로젝트별 명시
nara_crawler/data/
nara_relist/**/data/
nara_agui/data/
nara_openclaw/data/
nara_gov24_link_resolver/data/
**/raw_data/
**/refine_data/
**/refine_data_dev/
**/refined_data/
**/output/
**/results/

# OpenAPI JSON 평면 저장소 (nara_dashboard, nara_search)
# ※ src/data 같은 React 소스 폴더와 혼동을 피하려 별도 이름

# 공유 API 문서 데이터 루트 (nara_crawler 산출물 — git 제외)
nara_storage/

**/apidata/
# 테스트 fixture는 예외 (재현 가능한 계약 테스트용 소형 문서)
!**/tests/fixtures/apidata/
!**/tests/fixtures/apidata/**

# 실행 감사 기록 (런타임 생성, nara_openclaw)
**/runs/*.json

# API 메타
**/api_data/
**/api_docs/

# 임베딩 모델 (자동 다운로드, ~2.5GB)
**/models/
**/embeddings/

# 검색 인덱스 (재생성 가능)
**/storage/

# 캐시 / 청크 / 테스트 데이터
**/cache/
**/rag_chunks/
**/test_data/

# 크롤러 보조 (CSV 데이터베이스)
nara_crawler/util/scanner/database/*.csv


# ─────────────────────────────────────────────
# 백업 / 아카이브 / 레거시
# ─────────────────────────────────────────────
backups/
**/_archive/
**/archieve/
**/legacy/
nara_service_legacy/


# ─────────────────────────────────────────────
# 미디어 / 바이너리 (CSV 포함)
# ※ 문서용 이미지 커밋이 필요하면 개별 예외 추가
# ─────────────────────────────────────────────
*.png
*.svg
*.woff
*.csv
OSD/


# ─────────────────────────────────────────────
# 프로젝트별 잡종
# ─────────────────────────────────────────────
# 임시 메모
task.txt
ISSUE.md

# 크롤링 산출 패턴
media_links_*.json
uddi*
